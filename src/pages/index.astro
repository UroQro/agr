---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Andrés González de Rosenzweig, MD | Urology PGY-5">
  <main>
    <section class="relative bg-white overflow-hidden min-h-[95vh] flex items-center">
      <div class="absolute inset-0 z-0">
        <img 
          src="/images/hero-andres.png" 
          alt="Andrés González de Rosenzweig" 
          class="w-full h-full object-cover object-right lg:object-center opacity-95"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-white via-white/80 to-transparent lg:from-white/90 lg:via-white/30"></div>
      </div>

      <div class="container mx-auto px-6 relative z-10">
        <div class="max-w-2xl">
          <h1 class="text-5xl lg:text-7xl font-bold text-slate-900 leading-tight tracking-tight">
            Andrés González <br/> de Rosenzweig, MD
          </h1>
          <p class="mt-6 text-2xl lg:text-3xl text-slate-700 font-medium italic">
            Urology Senior Resident (PGY-5)
          </p>
          
          <div class="h-12"></div>

          <div class="flex flex-col sm:flex-row flex-wrap gap-5">
            <a href="https://www.instagram.com/uro.rosenzweig?igsh=NWI4ZHF6M3JoeGRq&utm_source=qr" 
               target="_blank" 
               rel="noopener noreferrer"
               class="inline-flex justify-center items-center px-8 py-4 bg-gradient-to-tr from-[#f09433] via-[#dc2743] to-[#bc1888] text-white font-bold rounded-2xl shadow-xl hover:scale-105 transition-all">
              Instagram
            </a>

            <a href="https://wa.me/524424671630" 
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex justify-center items-center px-8 py-4 bg-[#25D366] text-white font-bold rounded-2xl shadow-xl hover:scale-105 transition-all">
              WhatsApp
            </a>

            <a href="mailto:dr@uroandres.com" 
               class="inline-flex justify-center items-center px-8 py-4 border-2 border-slate-300 text-slate-800 font-bold rounded-2xl hover:bg-slate-50 transition-all">
              Más info
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>